# ==============================================================================
# SOVEREIGN BUSINESS ENGINE v4.0 — ENV EXAMPLE
# File: .env.example
# Tujuan: Template environment variables untuk seluruh ecosystem
# PENTING: File ini HANYA berisi placeholder — BUKAN nilai asli
# Copy file ini ke .dev.vars (untuk dev lokal) — JANGAN commit .dev.vars
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE — Canonical Database (Sovereign Bridge)
# Ref: https://supabase.com/dashboard → Settings → API
# ──────────────────────────────────────────────────────────────────────────────

# Project URL (format: https://[ref].supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key — privileged DB access (SERVER-SIDE ONLY, NEVER client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Anon Key — public/client DB access (pastikan RLS aktif)
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ──────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────────────────────────────────────────────────

# JWT Secret — untuk signing + verification auth tokens
# Generate: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-minimum-64-chars-here

# Master PIN — Founder login gate (Sovereign Tower)
# Gunakan angka tidak mudah ditebak
MASTER_PIN=your-secure-numeric-pin-here

# ──────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE — Infrastructure
# Ref: https://dash.cloudflare.com/profile/api-tokens
# ──────────────────────────────────────────────────────────────────────────────

# API Token — untuk wrangler deploy (scope: Pages:Edit)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Account ID — target deployment account
# Ref: CF Dashboard → Overview → Account ID (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here

# ──────────────────────────────────────────────────────────────────────────────
# AI / LLM — Agent Intelligence Layer
# ──────────────────────────────────────────────────────────────────────────────

# Groq API Key — Primary LLM provider (GRATIS, fast inference)
# Ref: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# LLM Base URL — set ke Groq endpoint (atau OpenAI jika pakai OpenAI)
# Groq (recommended): https://api.groq.com/openai/v1
# OpenAI (fallback): https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# LLM Model — model yang digunakan agents
# Groq options: llama-3.3-70b-versatile, mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# OpenAI API Key — OPSIONAL (fallback jika Groq tidak cukup)
OPENAI_API_KEY=your-openai-api-key-here-or-leave-empty

# LangChain API Key — untuk LangSmith tracing (opsional tapi direkomendasikan)
# Ref: https://smith.langchain.com
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=sovereign-engine

# ──────────────────────────────────────────────────────────────────────────────
# WHATSAPP — Fonnte API
# Ref: https://fonnte.com/dashboard
# STATUS: MISSING — harus diurus sebelum Phase 3
# ──────────────────────────────────────────────────────────────────────────────

# Fonnte Token — WA automation (BLOCKER untuk /api/wa/* routes)
FONNTE_TOKEN=your-fonnte-token-here

# ──────────────────────────────────────────────────────────────────────────────
# SCRAPING — Scout Agent
# Ref: https://www.scraperapi.com/dashboard
# ──────────────────────────────────────────────────────────────────────────────

# ScraperAPI Key — Instagram scout scraping
SCRAPERAPI_KEY=your-scraperapi-key-here

# ──────────────────────────────────────────────────────────────────────────────
# CREWAI — Deep Market Analysis Agent
# Ref: https://app.crewai.com
# Digunakan di Phase 6 (Agent Orchestration)
# ──────────────────────────────────────────────────────────────────────────────

# CrewAI Personal Access Token
CREWAI_PAT=your-crewai-pat-here

# CrewAI Organization ID
CREWAI_ORG_ID=your-crewai-org-id-here

# ──────────────────────────────────────────────────────────────────────────────
# SEARCH — Market Intelligence
# ──────────────────────────────────────────────────────────────────────────────

# SerpAPI Key — web search untuk agents
# Ref: https://serpapi.com/dashboard
SERPAPI_KEY=your-serpapi-key-here

# ──────────────────────────────────────────────────────────────────────────────
# GITHUB — CI/CD (opsional, hanya jika butuh automation)
# ──────────────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token — repo automation
# Ref: GitHub → Settings → Developer Settings → Personal Access Tokens
# Scope yang dibutuhkan: repo, workflow
GITHUB_PAT=your-github-pat-here

# ──────────────────────────────────────────────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────────────────────────────────────────────

# Environment: development / production
NODE_ENV=development

# App URL (untuk CORS, redirect, etc)
APP_URL=http://localhost:3000

# ==============================================================================
# CARA PAKAI:
# 1. cp .env.example .dev.vars
# 2. Edit .dev.vars dengan nilai asli (JANGAN commit .dev.vars)
# 3. Untuk production: wrangler pages secret put VAR_NAME --project-name [project]
# 4. Cek .gitignore memuat .dev.vars sebelum commit apa pun
# ==============================================================================
