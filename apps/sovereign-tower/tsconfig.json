{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@sovereign/auth": ["../../packages/auth/src/index.ts"],
      "@sovereign/types": ["../../packages/types/src/index.ts"],
      "@sovereign/db": ["../../packages/db/src/index.ts"],
      "@sovereign/integrations": ["../../packages/integrations/src/index.ts"],
      "@sovereign/prompt-contracts": ["../../packages/prompt-contracts/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/auth/src/**/*.ts",
    "../../packages/types/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
