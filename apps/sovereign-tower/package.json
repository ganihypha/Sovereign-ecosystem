{
  "name": "sovereign-tower",
  "version": "0.1.0",
  "private": true,
  "description": "Sovereign Tower — Private Founder-Only Command Center | Sovereign Business Engine v4.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev dist --ip 0.0.0.0 --port 3001",
    "build": "vite build",
    "build:check": "tsc --noEmit && echo 'TypeCheck PASS'",
    "typecheck": "tsc --noEmit",
    "deploy": "vite build && wrangler pages deploy dist --project-name sovereign-tower",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sovereign/auth": "workspace:*",
    "@sovereign/db": "workspace:*",
    "@sovereign/integrations": "workspace:*",
    "@sovereign/prompt-contracts": "workspace:*",
    "@sovereign/types": "workspace:*",
    "@supabase/supabase-js": "^2.101.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "typescript": "^5.3.3",
    "vite": "^8.0.3",
    "wrangler": "^3.78.0"
  }
}
