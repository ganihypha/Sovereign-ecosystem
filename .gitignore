# ==============================================================================
# SOVEREIGN ECOSYSTEM — .gitignore
# PENTING: File .dev.vars TIDAK BOLEH COMMIT ke repo mana pun
# ==============================================================================

# ─── ENVIRONMENT & SECRETS ───────────────────────────────────────────────────
.dev.vars
.env
.env.local
.env.production
.env.*.local
*.secret
secrets/

# ─── NODE.JS ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── BUILD OUTPUT ─────────────────────────────────────────────────────────────
dist/
build/
.output/
.cache/

# ─── CLOUDFLARE / WRANGLER ───────────────────────────────────────────────────
.wrangler/
wrangler-state/

# ─── TURBOREPO ────────────────────────────────────────────────────────────────
.turbo/

# ─── TYPESCRIPT ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── EDITOR ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── LOGS ─────────────────────────────────────────────────────────────────────
*.log
logs/
pids/
*.pid

# ─── TEMP ─────────────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
