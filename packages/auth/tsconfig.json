{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "esModuleInterop": true,
    "isolatedModules": false,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "../types/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
